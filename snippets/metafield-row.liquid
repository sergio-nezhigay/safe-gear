{% comment %}
  Renders a single metafield row

  Parameters:
  - block: The metafield_row block with settings
  - product: The current product object
{% endcomment %}

{% assign namespace = block.settings.metafield_namespace %}
{% assign key = block.settings.metafield_key %}
{% assign is_variant_metafield = block.settings.is_variant_metafield %}
{% assign rounding = block.settings.rounding | default: 'none' %}

{% comment %} Locale-aware label {% endcomment %}
{% assign locale = request.locale.iso_code %}
{% case locale %}
  {% when 'fi' %}{% assign row_label = block.settings.label_fi | default: block.settings.label %}
  {% when 'de' %}{% assign row_label = block.settings.label_de | default: block.settings.label %}
  {% when 'da' %}{% assign row_label = block.settings.label_da | default: block.settings.label %}
  {% when 'sv' %}{% assign row_label = block.settings.label_sv | default: block.settings.label %}
  {% when 'nb' %}{% assign row_label = block.settings.label_nb | default: block.settings.label %}
  {% when 'nl' %}{% assign row_label = block.settings.label_nl | default: block.settings.label %}
  {% when 'fr' %}{% assign row_label = block.settings.label_fr | default: block.settings.label %}
  {% when 'es' %}{% assign row_label = block.settings.label_es | default: block.settings.label %}
  {% when 'it' %}{% assign row_label = block.settings.label_it | default: block.settings.label %}
  {% when 'pt-PT' %}{% assign row_label = block.settings.label_pt | default: block.settings.label %}
  {% else %}{% assign row_label = block.settings.label %}
{% endcase %}

{% comment %} Handle special variant weight case {% endcomment %}
{% if namespace == 'variant' and key == 'weight' %}
  {% if product.variants.size > 0 %}
    {% comment %} Calculate min and max weight across all variants {% endcomment %}
    {% assign min_weight = null %}
    {% assign max_weight = null %}

    {% for variant in product.variants %}
      {% if variant.weight > 0 %}
        {% if min_weight == null or variant.weight < min_weight %}
          {% assign min_weight = variant.weight %}
        {% endif %}
        {% if max_weight == null or variant.weight > max_weight %}
          {% assign max_weight = variant.weight %}
        {% endif %}
      {% endif %}
    {% endfor %}

    {% if min_weight != null %}
      <tr {{ block.shopify_attributes }} data-rounding="{{ block.settings.rounding | default: 'none' }}">
        <td>
          <strong>{{ row_label }}</strong>
        </td>
        <td data-metafield-value>
          {% if min_weight == max_weight %}
            {% comment %} All variants have same weight {% endcomment %}
            {% assign weight_kg = min_weight | divided_by: 1000.0 %}
            {% if rounding == 'integer' %}{% assign weight_kg = weight_kg | round %}{% elsif rounding == '1' %}{% assign weight_kg = weight_kg | times: 10 | round | divided_by: 10.0 %}{% elsif rounding == '2' %}{% assign weight_kg = weight_kg | times: 100 | round | divided_by: 100.0 %}{% endif %}
            {{ weight_kg }} kg
          {% else %}
            {% comment %} Show weight range {% endcomment %}
            {% assign min_kg = min_weight | divided_by: 1000.0 %}
            {% assign max_kg = max_weight | divided_by: 1000.0 %}
            {% if rounding == 'integer' %}{% assign min_kg = min_kg | round %}{% assign max_kg = max_kg | round %}{% elsif rounding == '1' %}{% assign min_kg = min_kg | times: 10 | round | divided_by: 10.0 %}{% assign max_kg = max_kg | times: 10 | round | divided_by: 10.0 %}{% elsif rounding == '2' %}{% assign min_kg = min_kg | times: 100 | round | divided_by: 100.0 %}{% assign max_kg = max_kg | times: 100 | round | divided_by: 100.0 %}{% endif %}
            {{ min_kg }} - {{ max_kg }} kg
          {% endif %}
        </td>
      </tr>
    {% endif %}
  {% endif %}
{% else %}
  {% comment %} Regular metafield handling {% endcomment %}

  {% comment %} Get metafield value from variant or product {% endcomment %}
  {% if is_variant_metafield %}
    {% assign metafield_value = product.selected_or_first_available_variant.metafields[namespace][key] %}
  {% else %}
    {% assign metafield_value = product.metafields[namespace][key] %}
  {% endif %}

  {% if metafield_value != blank %}
    <tr
      {{ block.shopify_attributes }}
      data-rounding="{{ block.settings.rounding | default: 'none' }}"
      {% if is_variant_metafield %}
        data-variant-metafield="true"
        data-metafield-key="{{ namespace }}.{{ key }}"
        data-variant-row
      {% endif %}
    >
      <td>
        <strong>{{ row_label }}</strong>
      </td>
      <td data-metafield-value>
        {% assign sep = separator | default: ', ' %}
        {% if metafield_value.value.value and metafield_value.value.unit %}
          {% assign num = metafield_value.value.value %}
          {% if rounding != 'none' %}
            {% case rounding %}
              {% when 'integer' %}{% assign num = num | round %}{% when '1' %}{% assign num = num | times:10 | round | divided_by:10 %}{% when '2' %}{% assign num = num | times:100 | round | divided_by:100 %}{% endcase %}
          {% endif %}
          {{ num }} {{ metafield_value.value.unit }}
        {% elsif metafield_value.value %}
          {%- comment -%}For list metafields we detect the type and join the values with separator{%- endcomment -%}
          {% assign mf_type = metafield_value.type | default: '' %}
          {% if mf_type contains 'list.' and metafield_value.value != blank %}
            {{ metafield_value.value | join: sep }}
          {% else %}
            {% assign output_value = metafield_value.value %}
            {% if rounding != 'none' %}
              {% assign numeric = output_value | plus: 0 %}
              {% if numeric != 0 or output_value == '0' %}
                {% case rounding %}
                  {% when 'integer' %}{% assign output_value = numeric | round %}
                  {% when '1' %}{% assign output_value = numeric | times:10 | round | divided_by:10 %}
                  {% when '2' %}{% assign output_value = numeric | times:100 | round | divided_by:100 %}
                {% endcase %}
              {% endif %}
            {% endif %}
            {{ output_value }}
          {% endif %}
        {% else %}
          {% assign output_value = metafield_value %}
          {% if rounding != 'none' %}
            {% assign numeric = output_value | plus: 0 %}
            {% if numeric != 0 or output_value == '0' %}
              {% case rounding %}
                {% when 'integer' %}{% assign output_value = numeric | round %}
                {% when '1' %}{% assign output_value = numeric | times:10 | round | divided_by:10 %}
                {% when '2' %}{% assign output_value = numeric | times:100 | round | divided_by:100 %}
              {% endcase %}
            {% endif %}
          {% endif %}
          {{ output_value }}
        {% endif %}
      </td>
    </tr>
  {% elsif is_variant_metafield %}
    {% comment %} For variant metafields, render hidden row that can be shown later {% endcomment %}
    <tr
      {{ block.shopify_attributes }}      data-rounding="{{ block.settings.rounding | default: 'none' }}"      data-variant-metafield="true"
      data-metafield-key="{{ namespace }}.{{ key }}"
      data-variant-row
      style="display: none;"
    >
      <td>
        <strong>{{ row_label }}</strong>
      </td>
      <td data-metafield-value></td>
    </tr>
  {% endif %}
{% endif %}
