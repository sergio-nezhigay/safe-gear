      assign email_label = 'E-Mail'
      assign phone_label = 'Telefon'
      assign submit_label = 'Senden'
      assign postal_code_label = 'Postleitzahl'
      assign delivery_address_label = 'Lieferadresse'
      assign installation_service_label = 'Montageservice'
      assign additional_details_label = 'Weitere Details'
      assign additional_details_placeholder = 'Weitere Details (Treppen, Zugangsbeschränkungen, Boden usw.)'
      assign no_installation_text = 'Keine Montage erforderlich'
      assign delivery_option_text = 'Lieferung an den endgültigen Standort'
      assign installation_option_text = 'Lieferung + Verankerung an Boden/Wand'
    when 'es'
      assign modal_title = 'Estimación de transporte e instalación'
      assign modal_subtitle = 'Rellena este formulario para obtener un presupuesto personalizado de transporte e instalación.'
      assign name_label = 'Nombre'
      assign email_label = 'Correo electrónico'
      assign phone_label = 'Teléfono'
      assign submit_label = 'Enviar'
      assign postal_code_label = 'Código postal'
      assign delivery_address_label = 'Dirección de entrega'
      assign installation_service_label = 'Servicio de instalación'
      assign additional_details_label = 'Detalles adicionales'
      assign additional_details_placeholder = 'Detalles adicionales (escaleras, restricciones de acceso, suelo, etc.)'
      assign no_installation_text = 'No se necesita instalación'
      assign delivery_option_text = 'Entregado en la ubicación final'
      assign installation_option_text = 'Entregado + anclaje al suelo/pared'
    when 'fi'
      assign modal_title = 'Kuljetus- ja asennusarvio'
      assign modal_subtitle = 'Täytä tämä lomake saadaksesi räätälöidyn kuljetus- ja asennusarvion.'
      assign name_label = 'Nimi'
      assign email_label = 'Sähköposti'
      assign phone_label = 'Puhelin'
      assign submit_label = 'Lähetä'
      assign postal_code_label = 'Postinumero'
      assign delivery_address_label = 'Toimitusosoite'
      assign installation_service_label = 'Asennuspalvelu'
      assign additional_details_label = 'Lisätiedot'
      assign additional_details_placeholder = 'Lisätiedot (portaat, kulkurajoitukset, lattia jne.)'
      assign no_installation_text = 'Ei asennusta'
      assign delivery_option_text = 'Toimitettuna lopulliseen sijaintiin'
      assign installation_option_text = 'Toimitus + lattia-/seinäkiinnitys'
    when 'fr'
      assign modal_title = "Estimation de transport et d'installation"
      assign modal_subtitle = "Remplissez ce formulaire pour obtenir un devis personnalisé pour le transport et l'installation."
      assign name_label = 'Nom'
      assign email_label = 'E-mail'
      assign phone_label = 'Téléphone'
      assign submit_label = 'Envoyer'
      assign postal_code_label = 'Code postal'
      assign delivery_address_label = 'Adresse de livraison'
      assign installation_service_label = "Service d'installation"
      assign additional_details_label = 'Détails supplémentaires'
      assign additional_details_placeholder = "Détails supplémentaires (escaliers, restrictions d'accès, sol, etc.)"
      assign no_installation_text = "Aucune installation nécessaire"
      assign delivery_option_text = "Livré à l'emplacement final"
      assign installation_option_text = 'Livré + fixation au sol/mur'
    when 'it'
      assign modal_title = 'Preventivo di trasporto e installazione'
      assign modal_subtitle = 'Compila questo modulo per ricevere un preventivo personalizzato per trasporto e installazione.'
      assign name_label = 'Nome'
      assign email_label = 'Email'
      assign phone_label = 'Telefono'
      assign submit_label = 'Invia'
      assign postal_code_label = 'CAP'
      assign delivery_address_label = 'Indirizzo di consegna'
      assign installation_service_label = 'Servizio di installazione'
      assign additional_details_label = 'Dettagli aggiuntivi'
      assign additional_details_placeholder = 'Dettagli aggiuntivi (scale, restrizioni di accesso, pavimento, ecc.)'
      assign no_installation_text = 'Nessuna installazione'
      assign delivery_option_text = 'Consegnato nel luogo finale'
      assign installation_option_text = 'Consegnato + fissaggio a pavimento/parete'
    when 'nb'
      assign modal_title = 'Transport- og installasjonsestimat'
      assign modal_subtitle = 'Fyll ut dette skjemaet for å få et tilpasset tilbud på transport og installasjon.'
      assign name_label = 'Navn'
      assign email_label = 'E-post'
      assign phone_label = 'Telefon'
      assign submit_label = 'Send'
      assign postal_code_label = 'Postnummer'
      assign delivery_address_label = 'Leveringsadresse'
      assign installation_service_label = 'Monteringstjeneste'
      assign additional_details_label = 'Ytterligere detaljer'
      assign additional_details_placeholder = 'Ytterligere detaljer (trapper, tilgangsbegrensninger, gulv osv.)'
      assign no_installation_text = 'Ingen montering nødvendig'
      assign delivery_option_text = 'Levert til endelig plassering'
