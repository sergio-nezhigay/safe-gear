  assign name_label = 'Name'
  assign email_label = 'Email'
  assign phone_label = 'Phone'
  assign submit_label = 'Send'
  assign postal_code_label = 'Postal code'
  assign delivery_address_label = 'Delivery address'
  assign installation_service_label = 'Installation service'
  assign additional_details_label = 'Additional details'

  assign name_placeholder = name_label
  assign email_placeholder = email_label
  assign phone_placeholder = phone_label
  assign postal_code_placeholder = postal_code_label
  assign delivery_address_placeholder = delivery_address_label
  assign additional_details_placeholder = 'Additional details (stairs, access restrictions, floor, etc.)'
  assign no_installation_text = 'No installation needed'
  assign delivery_option_text = 'Delivered to final location'
  assign installation_option_text = 'Delivered + bolting to floor/wall'

