{%- doc -%}
  Transport Form Modal
  A modal dialog for requesting installation and transport estimates.
{%- enddoc -%}

{%- liquid
  assign locale_code = request.locale.iso_code | default: localization.language.iso_code | default: 'en'
  assign modal_title = section.settings.modal_title
  if modal_title == blank or modal_title == 'Transport & Installation Estimate'
    assign modal_title = 'Transport & Installation Estimate'
