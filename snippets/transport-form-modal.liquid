      assign phone_label = 'Telefon'
      assign submit_label = 'Send'
      assign postal_code_label = 'Postnummer'
      assign delivery_address_label = 'Leveringsadresse'
      assign installation_service_label = 'Monteringsservice'
      assign additional_details_label = 'Yderligere oplysninger'
      assign additional_details_placeholder = 'Yderligere oplysninger (trapper, adgangsbegrænsninger, gulv osv.)'
      assign no_installation_text = 'Ingen montering nødvendig'
      assign delivery_option_text = 'Leveret til endelig placering'
      assign installation_option_text = 'Leveret + gulv-/vægforankring'
    when 'de'
