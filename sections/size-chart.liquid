{% stylesheet %}
  .size-chart-section th,
  .size-chart-section td {
    text-align: center !important;
  }
  @media (min-width: 1024px) {
    .product-row .cut_td:first-child {
      width: 44%;
      text-align: left !important;
    }
  }
  .product-row .cut_td:first-child {
    text-align: left !important;
  }
  @media (max-width: 768px) {
    .size-chart-section table th:last-child,
    .size-chart-section table td:last-child {
      min-width: 55px;
    }
  }
  .product-row.active::after {
    background-color: #000000 !important;
  }
  .product-row.active.highlighted:active,
  .product-row.active.highlighted:hover,
  .product-row.active.highlighted {
    box-shadow: 0px 4px 12px -2px rgba(0, 0, 0, 0.35);
    z-index: 999;
    background-color: white !important;
  }
  .size-chart-section {
    display: block !important;
    width: 100% !important;
    max-width: 1390px !important;
    margin: 0 auto;
    --section-padding: var(--spacing-md, 16px);
    --table-border-radius: 8px;
    --table-gap: var(--spacing-lg, 24px);
    --table-header-bg: #f0f8ff;
    --table-row-even-bg: #fafafa;
    --table-row-odd-bg: #ffffff;
    --table-border-color: #eee;
    padding-block-start: 0;
    padding-block-end: var(--padding-block-end, clamp(24px, 5vw, 48px));
    display: unset;
    padding: 0 0;
  }

  .product-info__main-title {
    margin: 0 0 clamp(24px, 4vw, 48px) 0 !important;
  }

  .size-chart-section .page-width {
    padding: 0 25px;
    max-width: 1280px;
    margin: 0 auto;
  }

  @media (min-width: 990px) {
    .size-chart-section {
      --table-gap: clamp(32px, 4vw, 48px);
      padding-block-start: 0;
      padding-block-end: var(--padding-block-end, clamp(48px, 6vw, 72px));
    }
  }

  .custom-size_chart {
    max-width: 100% !important;
    margin: 0 auto;
    display: block;
  }

  .custom-size_chart thead th {
    font-size: 22px;
  }

  .size-chart-section > .product-info__main-title.h4 {
    max-width: 1200px;
    margin: 0 auto clamp(24px, 4vw, 48px) auto;
    padding: 0 30px;
    text-align: left !important;
  }

  .product-info__main-title {
    font-family: var(--font-primary--family);
    font-size: var(--font-h4--size);
    font-weight: var(--font-h4--weight);
    color: var(--font-h4--color);
    line-height: var(--font-h4--line-height);
    text-align: left !important;
    margin-bottom: clamp(24px, 4vw, 48px);
  }

  .size-chart-section .table-container {
    width: 100%;
    margin: 0 auto 0 auto;
    background: white;
    /*border-radius: 8px;*/
    overflow: visible;
  }

  .size-chart-section table {
    width: 100%;
    border-collapse: collapse;
  }

  .size-chart-section thead tr {
    background-color: var(--color-text-link);
  }

  .size-chart-section thead tr th {
    background-color: transparent;
  }

  .size-chart-section thead {
    color: white;
    text-align: left;
  }

  .size-chart-section table {
    border-collapse: separate;
    border-spacing: 0;
    /*border-radius: 6px;*/
    overflow: visible;
  }

  .size-chart-section thead th:first-child {
    border-top-left-radius: 6px;
    /*border-bottom-left-radius: 6px;*/
    overflow: hidden !important;
  }

  .size-chart-section thead th:last-child {
    border-top-right-radius: 6px;
    /*border-bottom-right-radius: 6px;*/
    overflow: hidden !important;
  }
  .size-chart-section th,
  .size-chart-section td {
    padding: 22px 8px;
    text-align: left;
    border-bottom: none;
  }

  .size-chart-section th {
    color: white;
    font-weight: bold;
    font-size: 16px;
  }

  .size-chart-section th .dimension-unit {
    font-size: 16px;
    font-weight: normal;
  }

  @media (min-width: 769px) {
    .size-chart-section td:first-child,
    .size-chart-section th:first-child {
      padding-left: 24px;
    }

    .size-chart-section td:last-child,
    .size-chart-section th:last-child {
      padding-right: 24px;
    }
  }

  .size-chart-section th:first-child {
    width: 30%;
    font-weight: 600;
  }

  .size-chart-section tbody tr {
    position: relative;
  }

  .size-chart-section tbody tr::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 24px;
    right: 24px;
    height: 1px;
    background-color: #eee;
  }

  .size-chart-section tr:last-child::after {
    display: none;
  }

  .size-chart-section .product-row:hover::after {
    display: none;
  }

  .size-chart-section td a {
    text-decoration: none;
    color: #000;
    transition: color 0.2s ease;
  }

  .size-chart-section td .product_title_ {
    color: var(--color-text-link);
    text-decoration: none;
    font-size: 16px;
    line-height: 20px;
    font-weight: 600;
  }

  /* Row hover styling */
  .size-chart-section .product-row {
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    border-left: none;
    border-right: none;
  }

  .size-chart-section .product-row:hover {
    box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.25);
    border: 1px solid #d0d0d0;
    border-left: 1px solid #d0d0d0;
    border-right: 1px solid #d0d0d0;
    transform: none;
    background-color: #ffff !important;
    z-index: 2;
  }

  .size-chart-section .price {
    color: #3cc561;
    font-weight: 600;
  }

  .size-chart-section .info-btn {
    color: white;
    padding: 10px 15px;
    text-align: center;
    display: inline-block;
    text-decoration: none;
    font-weight: bold;
    border: none;
    cursor: pointer;
    border-radius: 4px;
    background: #3cc561;
    transition: background-color 0.2s ease;
  }

  .size-chart-section .info-btn:hover {
    background: #2ea84d;
  }

  /* Tablet and Desktop: 71px header height, no text wrap */
  @media screen and (min-width: 750px) {
    .size-chart-section table thead {
      height: 71px;
    }

    .size-chart-section table thead tr {
      height: 71px;
    }

    .size-chart-section table thead th {
      height: 71px;
      padding-top: 12px;
      padding-bottom: 12px;
      /* white-space: nowrap; */
      vertical-align: middle;
      line-height: 1.2;
    }

    .size-chart-section table thead th .dimension-unit {
      display: inline;
      margin-left: 4px;
    }

    /* Optional: Add slight horizontal spacing if needed */
    .size-chart-section table thead th.cust_hkd {
      padding-left: 12px;
      padding-right: 12px;
    }
  }

  /* Optional: Desktop-specific adjustments (≥1024px) */
  @media screen and (min-width: 1024px) {
    .size-chart-section table thead th {
      padding-left: 16px;
      padding-right: 16px;
    }
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .size-chart-section .page-width {
      padding: 0 15px;
    }
    .size-chart-section .table-container {
      width: 100%;
      overflow-x: auto;
      position: relative;
    }

    .size-chart-section table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 600px;
    }

    .size-chart-section table th:first-child,
    .size-chart-section table td:first-child {
      position: sticky;
      left: 0;
      border-right: 2px solid #eee;
      min-width: 120px;
      max-width: 120px;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .size-chart-section table td:first-child {
      background-color: #fff;
    }

    .size-chart-section table th:first-child {
      background-color: var(--color-text-link);
      font-size: 12px;
      font-weight: 600;
      text-align: left;
      padding: 12px 8px;
      height: 100%;
      vertical-align: top;
      border: 0;
      text-align: center !important;
      display: flex !important;
      align-items: center;
      justify-content: center;
    }

    .size-chart-section table th,
    .size-chart-section table td {
      min-width: 100px;
      padding: 8px;
      border-bottom: none;
      text-align: left;
      font-size: 14px;
    }

    .size-chart-section table th {
      font-size: 14px;
      font-weight: 600;
      text-align: center;
      background-color: var(--color-text-link);
    }

    .size-chart-section table td:first-child a,
    .size-chart-section table th:first-child {
      display: block;
      word-break: break-word;
      line-height: 1.2;
    }

    .size-chart-section .cust_model {
      height: 125px !important;
    }
  }

  /* Accessibility improvements */
  .size-chart-section .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Performance optimizations */
  .size-chart-section {
    contain: layout;
  }

  .size-chart-section .table-container {
    will-change: auto;
  }
{% endstylesheet %}

