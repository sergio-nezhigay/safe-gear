{% comment %}
  Volume Pricing Block
  Shows a button to open the volume pricing contact form modal.
{% endcomment %}

{% liquid
  assign locale_code = request.locale.iso_code | default: localization.language.iso_code | default: 'en'
  assign button_text = block.settings.button_text

  case locale_code
    when 'da'
      assign locale_button_text = 'Forespørgsel om mængdepriser'
    when 'de'
      assign locale_button_text = 'Mengenpreise anfragen'
    when 'es'
      assign locale_button_text = 'Consultar precios por volumen'
    when 'fi'
      assign locale_button_text = 'Kysy määräalennushinnoista'
    when 'fr'
      assign locale_button_text = 'Demander un prix de volume'
    when 'it'
      assign locale_button_text = 'Richiedi prezzi quantità'
    when 'nb'
      assign locale_button_text = 'Forespør volumpriser'
    when 'nl'
      assign locale_button_text = 'Vraag volumekorting aan'
    when 'pt-PT'
      assign locale_button_text = 'Pedir preços por volume'
    when 'sv'
      assign locale_button_text = 'Fråga om volympriser'
    else
      assign locale_button_text = 'Inquire About Volume Pricing'
  endcase

  if button_text == blank or button_text == 'Inquire About Volume Pricing'
    assign button_text = locale_button_text
  endif
%}

<div class="volume-pricing-block" {{ block.shopify_attributes }}>
  <div class="volume-pricing-content">
    <button
      type="button"
      class="volume-pricing-link button {{ block.settings.button_style }}"
      on:click="#volume-pricing-modal/showDialog"
    >
      {{ button_text }}
    </button>
  </div>
</div>

{% schema %}
{
  "name": "Volume Pricing",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Inquire About Volume Pricing"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        {
          "value": "button--primary",
          "label": "Primary"
        },
        {
          "value": "button--secondary",
          "label": "Secondary"
        },
        {
          "value": "button--outline",
          "label": "Outline"
        }
      ],
      "default": "button--secondary"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .volume-pricing-block {
    width: 100%;
  }

  .volume-pricing-button {
    width: 100%;
    font-size: 20px;
  }
  /* Volume pricing CTA styled as link */
  .button.volume-pricing-link,
  button.volume-pricing-link {
    /* visual reset to look like text link */
    background: none;
    border: none;
    box-shadow: none;
    padding: 0;
    margin: 0;
    border-radius: 0;
    min-width: 0;
    height: auto;
    font-size: 20px;

    /* link-like appearance */
    color: var(--color-text-link);
    font-weight: 400;
    text-decoration: none;
    cursor: pointer;

    /* keep inline flow */
    display: inline;
  }

  /* hover & focus states */
  .button.volume-pricing-link:hover,
  button.volume-pricing-link:hover,
  .button.volume-pricing-link:focus-visible,
  button.volume-pricing-link:focus-visible {
    text-decoration: underline;
    color: var(--color-text-link);
  }
{% endstylesheet %}
